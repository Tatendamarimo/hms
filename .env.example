# Copy to .env and adjust. Never commit .env.

# Django
DJANGO_SECRET_KEY=change-me-generate-a-real-one
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (host port 5435 to avoid collisions with other local Postgres instances)
DATABASE_URL=postgres://hms:hms@localhost:5435/hms

# Redis / Celery
REDIS_URL=redis://localhost:6381/0

# Frontend origin (CORS/CSRF in dev)
FRONTEND_ORIGIN=http://localhost:5173

# Sessions
SESSION_IDLE_TIMEOUT_SECONDS=1800

# Backups
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
# BACKUP_GPG_RECIPIENT=ops@example.com   # uncomment to encrypt backups
